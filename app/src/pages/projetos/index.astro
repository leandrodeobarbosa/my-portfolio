---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectList from '../../components/ProjectList.astro';
import { PROJECTS as projects } from '../../domains/portfolio/projects';
import { SITE_PROJECTS_DESCRIPTION } from '../../consts';

// Use default variant for all projects to ensure consistent sizing
const variantOverrides: Record<string, 'featured' | 'secondary' | 'compact' | 'horizontal'> = {}
---

<BaseLayout
	title="Todos os Projetos"
	description={SITE_PROJECTS_DESCRIPTION}
	type='projects'
	slug='/projects'
>
  <div class='container'>
    <div class='page-stack'>
      <section class='page-intro'>
        <h1 class='text-3xl font-bold font-mono leading-tight text-balance sm:text-4xl'># Todos os Projetos</h1>
        <p class='measure-text text-base leading-relaxed text-zinc-200 sm:text-lg'>Projetos focados em plataforma, automação e experiência do desenvolvedor, incluindo iniciativas em infraestrutura como código, CI/CD e segurança.</p>
      </section>
    <ProjectList projects={projects} featured={false} variantOverrides={variantOverrides}/>
    </div>
  </div>
</BaseLayout>
