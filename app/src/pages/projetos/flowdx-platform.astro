<script>
  // @ts-nocheck
  var observer = null;
  var isInitialized = false;

  function cleanup() {
    if (observer) {
      observer.disconnect();
      observer = null;
    }
    isInitialized = false;
  }

  function init() {
    if (isInitialized) {
      cleanup();
    }

    var navLinks = document.querySelectorAll('.nav-link');

    if (navLinks.length === 0) return;

    // Get the section IDs that have corresponding nav links
    var validSectionIds = [];
    navLinks.forEach(function(link) {
      var sectionId = link.getAttribute('data-section');
      if (sectionId) validSectionIds.push(sectionId);
    });

    // Only query sections that have nav links (filter out sections like architecture-highlights)
    var validSections = [];
    validSectionIds.forEach(function(id) {
      var section = document.getElementById(id);
      if (section) validSections.push(section);
    });

    if (validSections.length === 0) return;

    // Get the nav link for a section id
    function getNavLink(id) {
      return document.querySelector('.nav-link[data-section="' + id + '"]');
    }

    // Set active nav link
    function setActive(id) {
      navLinks.forEach(function(link) {
        link.classList.remove('active');
      });
      var link = getNavLink(id);
      if (link) link.classList.add('active');
    }

    // Find which section is currently most visible in the viewport
    function getCurrentSection() {
      var scrollY = window.scrollY;
      var centerY = scrollY + window.innerHeight / 2;
      var bestSection = null;
      var bestScore = -Infinity;

      validSections.forEach(function(section) {
        var rect = section.getBoundingClientRect();
        var top = rect.top + scrollY;
        var bottom = top + rect.height;
        var height = rect.height;

        if (height <= 0) return;

        // Calculate overlap score - prefer sections where viewport center is inside the section
        var score;
        if (centerY >= top && centerY < bottom) {
          // Center is inside this section - give it highest priority
          score = 2;
        } else if (centerY < top) {
          // Section is below viewport center
          score = 1;
        } else {
          // Section is above viewport center - still active but lower priority
          score = 0;
        }

        if (score > bestScore) {
          bestScore = score;
          bestSection = section.getAttribute('id');
        }
      });

      return bestSection;
    }

    // Use IntersectionObserver with a reading zone in the middle of viewport
    var options = {
      root: null,
      // The intersection zone is from 20% to 80% of viewport height
      // A section becomes "active" when it enters this zone
      rootMargin: '-20% 0px -20% 0px',
      threshold: 0
    };

    observer = new IntersectionObserver(function(entries) {
      // Find the entry that is intersecting and is highest in the viewport
      var intersectingEntries = [];
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          intersectingEntries.push(entry);
        }
      });

      if (intersectingEntries.length > 0) {
        // Sort by vertical position (lowest = highest on page = first in DOM)
        intersectingEntries.sort(function(a, b) {
          return a.boundingClientRect.top - b.boundingClientRect.top;
        });
        var topEntry = intersectingEntries[0];
        var id = topEntry.target.getAttribute('id');
        if (id && validSectionIds.indexOf(id) !== -1) {
          setActive(id);
        }
      }
    }, options);

    validSections.forEach(function(section) {
      observer.observe(section);
    });

    // Set initial active link after a short delay
    setTimeout(function() {
      var id = getCurrentSection();
      if (id) setActive(id);
    }, 150);

    // Handle click on nav links for smooth scroll
    navLinks.forEach(function(link) {
      link.addEventListener('click', function(e) {
        e.preventDefault();
        var href = link.getAttribute('href');
        if (!href) return;
        var targetId = href.substring(1);
        var target = document.getElementById(targetId);
        if (target) {
          var offset = 150;
          var rect = target.getBoundingClientRect();
          var top = rect.top + window.scrollY - offset;
          window.scrollTo({ top: top, behavior: 'smooth' });
          setActive(targetId);
        }
      });
    });

    // Update on scroll with throttling
    var scrollTimer = null;
    window.addEventListener('scroll', function() {
      if (scrollTimer) return;
      scrollTimer = setTimeout(function() {
        scrollTimer = null;
        var id = getCurrentSection();
        if (id) setActive(id);
      }, 50);
    }, { passive: true });

    isInitialized = true;
  }

  // Re-initialize on view transitions
  document.addEventListener('astro:page-load', function() {
    cleanup();
    init();
  }, { once: false });

  // Initialize on page load
  if (document.readyState === 'complete') {
    init();
  } else {
    window.addEventListener('load', function() {
      init();
    }, { once: true });
  }
</script>

