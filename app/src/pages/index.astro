---
import { SITE_TITLE, SITE_TAGLINE, SITE_DESCRIPTION } from '../consts';
import BaseLayout from '../layouts/BaseLayout.astro';
import { PROJECTS as projects } from '../domains/portfolio/projects';
import ProjectList from '../components/ProjectList.astro'

const top3Projects = projects.slice(0, 2);
---

<BaseLayout title={SITE_TITLE + ' - ' + SITE_TAGLINE} description={SITE_DESCRIPTION}>
	<div class='container'>
		<main>
			<!-- Documentation Style Hero Section -->
			<div class='max-w-4xl mb-20'>
				<!-- Name, Seniority Micro-signal, and Keywords -->
				<div class='flex-1 min-w-0 pt-1'>
					<h1 class='text-3xl sm:text-4xl font-bold text-zinc-100 font-mono mb-3'>
						Leandro de Oliveira Barbosa
					</h1>

					<!-- Role Badge - Enhanced glassmorphism -->
					<div class='mb-4'>
						<span class='work-badge'>
							DevOps & Platform Engineer
						</span>
					</div>

			<!-- Introduction - Enhanced visual hierarchy -->
			<div class='mb-6'>
				<p class='text-lg sm:text-xl leading-relaxed text-zinc-200 max-w-[65ch] mb-4'>
					<span class='text-[var(--color-accent)]'>Desenvolvo plataformas de nuvem</span> com foco em automação e pipelines que aceleram o ciclo de entrega e melhoram a experiência do desenvolvedor.
				<a href='/sobre/' class='inline-flex items-center gap-1 ml-2 text-xs font-mono text-zinc-300 hover:text-[var(--color-accent)] transition-all duration-200 no-underline opacity-70 hover:opacity-100 hover:translate-x-0.5'>
					<span class='text-[var(--color-accent)]'>cat</span> sobre.md <span class='text-zinc-400'>→</span>
				</a>
				</p>

				<!-- Key Stack - Flowchart Style -->
				<div class='skill-flowchart mb-4' role='list' aria-label='Tech stack flowchart'>
					<div class='flow-node' role='listitem'>
						<div class='flow-badge group'>
							<span class='flow-label'>Cloud</span>
							<span class='flow-tech'>AWS</span>
						</div>
						<div class='flow-arrow' aria-hidden='true'>
							<svg width='24' height='24' viewBox='0 0 24 24' fill='none' xmlns='http://www.w3.org/2000/svg'>
								<path d='M5 12H19M19 12L13 6M19 12L13 18' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/>
							</svg>
						</div>
					</div>
					<div class='flow-node' role='listitem'>
						<div class='flow-badge group'>
							<span class='flow-label'>IaC</span>
							<span class='flow-tech'>TERRAFORM</span>
						</div>
						<div class='flow-arrow' aria-hidden='true'>
							<svg width='24' height='24' viewBox='0 0 24 24' fill='none' xmlns='http://www.w3.org/2000/svg'>
								<path d='M5 12H19M19 12L13 6M19 12L13 18' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/>
							</svg>
						</div>
					</div>
					<div class='flow-node' role='listitem'>
						<div class='flow-badge group'>
							<span class='flow-label'>CI/CD</span>
							<span class='flow-tech'>GITHUB ACTIONS</span>
						</div>
						<div class='flow-arrow' aria-hidden='true'>
							<svg width='24' height='24' viewBox='0 0 24 24' fill='none' xmlns='http://www.w3.org/2000/svg'>
								<path d='M5 12H19M19 12L13 6M19 12L13 18' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/>
							</svg>
						</div>
					</div>
					<div class='flow-node' role='listitem'>
						<div class='flow-badge group'>
							<span class='flow-label'>Runtime</span>
							<span class='flow-tech'>NODE.JS</span>
						</div>
						<div class='flow-arrow' aria-hidden='true'>
							<svg width='24' height='24' viewBox='0 0 24 24' fill='none' xmlns='http://www.w3.org/2000/svg'>
								<path d='M5 12H19M19 12L13 6M19 12L13 18' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'/>
							</svg>
						</div>
					</div>
					<div class='flow-node' role='listitem'>
						<div class='flow-badge group'>
							<span class='flow-label'>OS</span>
							<span class='flow-tech'>LINUX</span>
						</div>
					</div>
				</div>


			</div>





			</div>

			<!-- Projects - Markdown Style Header -->
			<div class='mb-12'>
				<div class='flex justify-between items-center gap-2 mb-6'>
					<h2 class='text-xl font-mono font-bold text-zinc-100'>## Projetos</h2>
				</div>
				<ProjectList projects={top3Projects} featured={true} horizontal={true}/>
			</div




		</main>
	</div>
</BaseLayout>
