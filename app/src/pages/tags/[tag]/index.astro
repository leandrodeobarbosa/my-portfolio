---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostsByYear from '../../../components/PostsByYear.astro';
import { slugify } from '../../../utils';

type BlogPost = CollectionEntry<'blog'>;

// Tag descriptions for common tags
const tagDescriptions: Record<string, string> = {
  'welcome': 'Posts de boas-vindas e introdução ao blog. Perfeito para novos visitantes conhecerem o conteúdo e propósito do blog.',
  'Welcome': 'Posts de boas-vindas e introdução ao blog. Perfeito para novos visitantes conhecerem o conteúdo e propósito do blog.',
};

// Tag display names for prettier URLs
const tagDisplayNames: Record<string, string> = {
  'welcome': 'Welcome',
  'Welcome': 'Welcome',
};

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  
  // Get all unique tags from all posts
  const allTags = posts.flatMap((post: BlogPost) => post.data.tags || []);
  const uniqueTags = [...new Set(allTags)] as string[];
  
  return uniqueTags.map((tag: string) => ({
    params: { tag: slugify(tag) },
    props: { 
      tag: tag,
      posts: posts.filter((post: BlogPost) => post.data.tags?.includes(tag))
    }
  }));
}

interface Props {
  tag: string;
  posts: BlogPost[];
}

const { tag, posts } = Astro.props;
const sortedPosts = posts.sort((a: BlogPost, b: BlogPost) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const postCount = sortedPosts.length;

// Get related tags from posts that have this tag
const relatedTags = [...new Set(
  sortedPosts.flatMap((post) => post.data.tags || []).filter((t) => t !== tag)
)].slice(0, 8);

const displayTag = tagDisplayNames[tag] || tag;
const tagDescription = tagDescriptions[tag] || `Todos os posts marcados com "${tag}"`;

const title = `${displayTag}`;
const description = tagDescription;
---

<BaseLayout
  title={title}
  description={description}
>
  <div class='container'>
    <!-- Breadcrumb Navigation -->
    <nav class='mb-6 text-sm font-mono text-zinc-500 dark:text-zinc-400'>
      <a href='/' class='hover:text-[var(--color-accent)] transition-colors'>Home</a>
      <span class='mx-2'>/</span>
      <a href='/posts/' class='hover:text-[var(--color-accent)] transition-colors'>Posts</a>
      <span class='mx-2'>/</span>
      <a href='/tags/' class='hover:text-[var(--color-accent)] transition-colors'>Tags</a>
      <span class='mx-2'>/</span>
      <span class='text-[var(--color-accent)]'>{displayTag}</span>
    </nav>

    <!-- Hero Section -->
    <header class='mb-10 p-6 bg-gradient-to-br from-zinc-50 to-zinc-100 dark:from-zinc-800 dark:to-zinc-900 rounded-xl border border-[var(--color-border-subtle)]'>
      <div class='flex flex-col sm:flex-row sm:items-center gap-4 mb-4'>
        <div class='inline-flex items-center justify-center w-14 h-14 bg-[var(--color-accent)]/10 rounded-xl'>
          <svg xmlns='http://www.w3.org/2000/svg' class='w-7 h-7 text-[var(--color-accent)]' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'>
            <path d='M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z'/>
            <line x1='7' y1='7' x2='7.01' y2='7'/>
          </svg>
        </div>
        <div class='flex-1'>
          <h1 class='text-3xl sm:text-4xl font-bold font-mono mb-2'># {displayTag}</h1>
          <p class='text-lg text-zinc-700 dark:text-zinc-300 max-w-2xl'>{tagDescription}</p>
        </div>
      </div>
      
      <!-- Meta Info Bar -->
      <div class='flex flex-wrap items-center gap-4 pt-4 border-t border-[var(--color-border-subtle)]'>
        <div class='flex items-center gap-2'>
          <span class='text-sm bg-[var(--color-accent)]/10 text-[var(--color-accent)] px-3 py-1 rounded-full font-mono font-medium'>
            {postCount} {postCount === 1 ? 'post' : 'posts'}
          </span>
        </div>
        
        <!-- Related Tags -->
        {relatedTags.length > 0 && (
          <div class='flex items-center gap-2 flex-wrap'>
            <span class='text-sm text-zinc-500 dark:text-zinc-400'>Related:</span>
            {relatedTags.map((relatedTag: string) => (
              <a 
                href={`/tags/${slugify(relatedTag)}/`}
                class='text-sm px-2 py-0.5 bg-zinc-200 dark:bg-zinc-700 text-zinc-700 dark:text-zinc-300 rounded hover:bg-[var(--color-accent)]/20 hover:text-[var(--color-accent)] transition-colors'
              >
                {relatedTag}
              </a>
            ))}
          </div>
        )}
        
        <a 
          href='/posts/' 
          class='ml-auto inline-flex items-center gap-2 text-[var(--color-accent)] hover:underline font-mono text-sm'
        >
          <svg xmlns='http://www.w3.org/2000/svg' class='w-4 h-4' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'>
            <path d='M19 12H5M12 19l-7-7 7-7'/>
          </svg>
          Ver todos os posts
        </a>
      </div>
    </header>
    
    {sortedPosts.length > 0 ? (
      <PostsByYear posts={sortedPosts} />
    ) : (
      <div class='py-12 text-center bg-zinc-50 dark:bg-zinc-800/50 rounded-xl border border-[var(--color-border-subtle)]'>
        <svg xmlns='http://www.w3.org/2000/svg' class='w-16 h-16 mx-auto mb-4 text-zinc-300 dark:text-zinc-600' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'>
          <circle cx='12' cy='12' r='10'/>
          <path d='M16 16s-1.5-2-4-2-4 2-4 2'/>
          <line x1='9' y1='9' x2='9.01' y2='9'/>
          <line x1='15' y1='9' x2='15.01' y2='9'/>
        </svg>
        <p class='text-zinc-600 dark:text-zinc-400 text-lg mb-4'>Nenhum post encontrado com esta tag.</p>
        <a href='/posts/' class='inline-flex items-center gap-2 px-4 py-2 bg-[var(--color-accent)] text-white rounded-lg hover:bg-[var(--color-accent)]/90 transition-colors'>
          <svg xmlns='http://www.w3.org/2000/svg' class='w-4 h-4' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'>
            <path d='M19 12H5M12 19l-7-7 7-7'/>
          </svg>
          Voltar para todos os posts
        </a>
      </div>
    )}
  </div>
</BaseLayout>
