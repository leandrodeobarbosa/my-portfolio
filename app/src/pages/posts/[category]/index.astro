---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostsByYear from '../../../components/PostsByYear.astro';
import { slugify } from '../../../utils';
import { BLOG_CATEGORIES, DEFAULT_CATEGORY_ICON, type CategorySlug } from '@src/domains/blog/categories';

type BlogPost = CollectionEntry<'blog'>;

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  
  // Get all unique categories
  const categories = [...new Set(posts.map((post) => post.data.category).filter(Boolean))];
  
  return categories.map((category) => ({
    params: { category },
    props: { 
      category: category!,
      posts: posts.filter((post) => post.data.category === category)
    }
  }));
}

const { category, posts } = Astro.props;
const sortedPosts = posts.sort((a: BlogPost, b: BlogPost) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Get category data from domain (Single Source of Truth)
const categoryData = BLOG_CATEGORIES[category as CategorySlug];
const categoryDisplayName = categoryData?.label || category;
const categoryDescription = categoryData?.description || `Todos os posts sobre ${category}`;
const categoryIcon = categoryData?.icon || DEFAULT_CATEGORY_ICON;

const postCount = sortedPosts.length;
const title = `${categoryDisplayName}`;
const description = `Todos os posts da categoria ${categoryDisplayName} - Leia artigos sobre ${categoryDisplayName.toLowerCase()} no blog de Leandro de O Barbosa`;

// Get all unique tags from posts in this category
const categoryTags = [...new Set(
  sortedPosts.flatMap((post) => post.data.tags || [])
)].slice(0, 10);
---

<BaseLayout
  title={title}
  description={description}
>
  <div class='container'>
    <!-- Breadcrumb Navigation -->
    <nav class='mb-6 text-sm font-mono text-zinc-500 dark:text-zinc-400'>
      <a href='/' class='hover:text-[var(--color-accent)] transition-colors'>Home</a>
      <span class='mx-2'>/</span>
      <a href='/posts/' class='hover:text-[var(--color-accent)] transition-colors'>Posts</a>
      <span class='mx-2'>/</span>
      <span class='text-[var(--color-accent)]'>{categoryDisplayName}</span>
    </nav>

    <!-- Hero Section -->
    <header class='mb-10 p-6 bg-gradient-to-br from-zinc-50 to-zinc-100 dark:from-zinc-800 dark:to-zinc-900 rounded-xl border border-[var(--color-border-subtle)]'>
      <div class='flex flex-col sm:flex-row sm:items-center gap-4 mb-4'>
        <div class='inline-flex items-center justify-center w-14 h-14 bg-[var(--color-accent)]/10 rounded-xl'>
          <Fragment set:html={categoryIcon} />
        </div>
        <div class='flex-1'>
          <h1 class='text-3xl sm:text-4xl font-bold font-mono mb-2'># {title}</h1>
          <p class='text-lg text-zinc-700 dark:text-zinc-300 max-w-2xl'>{categoryDescription}</p>
        </div>
      </div>
      
      <!-- Meta Info Bar -->
      <div class='flex flex-wrap items-center gap-4 pt-4 border-t border-[var(--color-border-subtle)]'>
        <div class='flex items-center gap-2'>
          <span class='text-sm bg-[var(--color-accent)]/10 text-[var(--color-accent)] px-3 py-1 rounded-full font-mono font-medium'>
            {postCount} {postCount === 1 ? 'post' : 'posts'}
          </span>
        </div>
        
        <!-- Tags in this category -->
        {categoryTags.length > 0 && (
          <div class='flex items-center gap-2 flex-wrap'>
            <span class='text-sm text-zinc-500 dark:text-zinc-400'>Tags:</span>
            {categoryTags.map((tag: string) => (
              <a 
                href={`/tags/${slugify(tag)}/`}
                class='text-sm px-2 py-0.5 bg-zinc-200 dark:bg-zinc-700 text-zinc-700 dark:text-zinc-300 rounded hover:bg-[var(--color-accent)]/20 hover:text-[var(--color-accent)] transition-colors'
              >
                {tag}
              </a>
            ))}
          </div>
        )}
        
        <a 
          href='/posts/' 
          class='ml-auto inline-flex items-center gap-2 text-[var(--color-accent)] hover:underline font-mono text-sm'
        >
          <svg xmlns='http://www.w3.org/2000/svg' class='w-4 h-4' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'>
            <path d='M19 12H5M12 19l-7-7 7-7'/>
          </svg>
          Ver todos os posts
        </a>
      </div>
    </header>
    
    {sortedPosts.length > 0 ? (
      <PostsByYear posts={sortedPosts} />
    ) : (
      <div class='py-12 text-center bg-zinc-50 dark:bg-zinc-800/50 rounded-xl border border-[var(--color-border-subtle)]'>
        <svg xmlns='http://www.w3.org/2000/svg' class='w-16 h-16 mx-auto mb-4 text-zinc-300 dark:text-zinc-600' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'>
          <path d='M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z'/>
          <polyline points='14 2 14 8 20 8'/>
        </svg>
        <p class='text-zinc-600 dark:text-zinc-400 text-lg mb-4'>Nenhum post encontrado nesta categoria.</p>
        <a href='/posts/' class='inline-flex items-center gap-2 px-4 py-2 bg-[var(--color-accent)] text-white rounded-lg hover:bg-[var(--color-accent)]/90 transition-colors'>
          <svg xmlns='http://www.w3.org/2000/svg' class='w-4 h-4' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'>
            <path d='M19 12H5M12 19l-7-7 7-7'/>
          </svg>
          Voltar para todos os posts
        </a>
      </div>
    )}
  </div>
</BaseLayout>
