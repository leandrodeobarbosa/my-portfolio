---
// StructuredData.astro - JSON-LD Structured Data for SEO
// Implements Person, BlogPosting, and Website schemas optimized for E-E-A-T

import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';

interface Props {
  type: 'website' | 'person' | 'about' | 'projects';
  title?: string;
  description?: string;
  image?: string;
  slug?: string;
  pubDate?: Date;
  updatedDate?: Date;
}

const {
  type,
  title,
  description,
  slug,
} = Astro.props;

// Site-wide values
const SITE_URL = 'https://leandrodeobarbosa.dev';
const PERSON_NAME = 'Leandro de Oliveira Barbosa';
const JOB_TITLE = 'DevOps & Platform Engineer';
const PROFILE_IMAGE = '/leandrodeo_barbosa.png';

// Social profiles
const SOCIAL_PROFILES = {
  github: 'https://github.com/leandrodeobarbosa',
  linkedin: 'https://linkedin.com/in/leandrodeobarbosa',
  x: 'https://x.com/le_deobarbosa',
};

// Helper to convert relative URL to absolute
const toAbsoluteUrl = (path: string) => {
  if (path.startsWith('http')) return path;
  return `${SITE_URL}${path}`;
};

// Generate JSON-LD based on page type
const generateJsonLd = () => {
  const profileImageUrl = toAbsoluteUrl(PROFILE_IMAGE);
  const currentUrl = slug ? toAbsoluteUrl(slug) : SITE_URL;

  switch (type) {
    case 'person':
      return {
        '@context': 'https://schema.org',
        '@type': 'Person',
        name: PERSON_NAME,
        jobTitle: JOB_TITLE,
        url: SITE_URL,
        image: profileImageUrl,
        sameAs: [
          SOCIAL_PROFILES.github,
          SOCIAL_PROFILES.linkedin,
          SOCIAL_PROFILES.x,
        ],
        description: description || SITE_DESCRIPTION,
      };

    case 'about':
      return {
        '@context': 'https://schema.org',
        '@type': 'ProfilePage',
        name: title || 'Sobre',
        description: description || SITE_DESCRIPTION,
        mainEntity: {
          '@type': 'Person',
          name: PERSON_NAME,
          jobTitle: JOB_TITLE,
          url: SITE_URL,
          image: profileImageUrl,
          sameAs: [
            SOCIAL_PROFILES.github,
            SOCIAL_PROFILES.linkedin,
            SOCIAL_PROFILES.x,
          ],
        },
      };

    case 'projects':
      return {
        '@context': 'https://schema.org',
        '@type': 'CollectionPage',
        name: title || 'Projetos',
        description: description || SITE_DESCRIPTION,
        url: currentUrl,
        mainEntity: {
          '@type': 'Person',
          name: PERSON_NAME,
          jobTitle: JOB_TITLE,
          url: SITE_URL,
        },
      };

    case 'website':
    default:
      return {
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: SITE_TITLE,
        description: SITE_DESCRIPTION,
        url: SITE_URL,
        publisher: {
          '@type': 'Person',
          name: PERSON_NAME,
        },

      };
  }
};

const jsonLd = generateJsonLd();
---

<script is:inline type='application/ld+json' set:html={JSON.stringify(jsonLd, null, 2)} />
