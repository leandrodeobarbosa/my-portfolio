---
import HeaderLink from './HeaderLink.astro';
import SocialIcons from '../../components/SocialIcons.astro';
import { NAV_ROUTES } from '@src/domains/navigation/routes';

// Menu built from domain (Single Source of Truth)
const menu = NAV_ROUTES.map((route) => ({
	link: route.path,
	label: route.label,
}));

	// Get current path for terminal PWD display
	const currentPath = Astro.url.pathname;
	const normalizedPath = currentPath.replace(/\/$/, '').slice(1) || '';
	const pathSegments = normalizedPath.split('/').filter(Boolean);

	// Build labels from domains (Single Source of Truth)
	const navLabels: Record<string, string> = {
		'/': '~', // UI-specific override for root
		...Object.fromEntries(
			NAV_ROUTES.map(route => [route.path, route.label])
		),
	};

	interface NavItem {
		label: string;
		path: string;
		isLast?: boolean;
	}

	// Build navigation hierarchy for breadcrumb
	const buildNavHierarchy = (): NavItem[] => {
		const hierarchy: NavItem[] = [{ label: '~', path: '/' }];
		let accumulatedPath = '';

		pathSegments.forEach((segment, index) => {
			accumulatedPath += `/${segment}`;
			// Ensure we look up with trailing slash for routes
			const lookupPath = accumulatedPath.endsWith('/') ? accumulatedPath : `${accumulatedPath}/`;
			// Use navLabels from domains, fallback to segment
			const translatedLabel = navLabels[lookupPath] || navLabels[accumulatedPath] || navLabels[segment] || segment;
			const isLast = index === pathSegments.length - 1;
			hierarchy.push({
				label: translatedLabel,
				path: accumulatedPath + '/',
				isLast
			});
		});

		return hierarchy;
	};

	const navHierarchy = buildNavHierarchy();
---

<header
	id='site-header'
	class:list={[
		'fixed top-0 left-0 right-0 flex items-center w-full transition-all duration-300 z-[999] bg-[var(--color-bg-primary)]/95 backdrop-blur-md border-b border-transparent'
	]}
>
	<div class='container'>
		<nav class='flex gap-4 items-center justify-between py-3'>
			<!-- Logo Section (Left) - Interactive Terminal Breadcrumb -->
			<h2 class='m-0'>
				<a href='/' class='group flex gap-1.5 items-center text-sm font-bold no-underline font-mono opacity-90 transition-all duration-200' aria-label='Home - leandro@devops'>
					<span class="text-[var(--color-accent)]" id="terminal-text">leandro@devops</span>
					<span class="text-zinc-300">:</span>

					<!-- Terminal Breadcrumb -->
					<nav class='flex items-center gap-0.5' aria-label='NavegaçãoBreadcrumb'>
						{
							navHierarchy.map((item, index) => (
								<>
									{index > 0 && <span class="text-zinc-300 mx-0.5">/</span>}
									{
										item.isLast || item.label === '~' ? (
											<span class:list={[
												"text-zinc-100",
												"max-w-[100px]",
												"sm:max-w-[150px]",
												"truncate",

												"transition-colors",
												"duration-200",

											]} title={item.path}>
												{item.label}
											</span>
										) : (
											<a
												href={item.path}
												class:list={[
													"text-zinc-600",
													"text-zinc-400",
													"hover:text-[var(--color-accent)]",
													"transition-colors",
													"duration-150",
													"truncate",
													"max-w-[70px]",
													"sm:max-w-[100px]"
												]}
												title={item.label}
											>
												{item.label}
											</a>
										)
									}
								</>
							))
						}
					</nav>
					<span id="terminal-cursor"></span>
				</a>
			</h2>

			<!-- Navigation Links (Terminal Style - File Directory Tabs) -->
			<div class='hidden lg:flex items-center gap-1 font-mono text-sm'>
				{
					menu.map((item) => (
						<HeaderLink
							class:list={[
								"px-3 py-2 text-zinc-300 hover:text-[var(--color-accent)] hover:bg-[var(--color-bg-secondary)] rounded transition-all duration-200",
								{ 'sobre-link': item.link === '/sobre/' }
							]}
							href={item.link}
						>
							{item.label}
						</HeaderLink>
					))
				}
			</div>

			<!-- Social Icons & Theme Toggle (Right) -->
			<div class='flex items-center gap-1'>
				<!-- Mobile: Hamburger Menu -->
				<button
					class='lg:hidden p-2.5 rounded-lg hover:bg-[var(--color-bg-secondary)] transition-colors duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] focus-visible:ring-offset-2'
					id='mobileMenuBtn'
					aria-label='Toggle navigation menu'
					aria-expanded='false'
					aria-controls='mobileMenu'
				>
					<svg class='menu-icon w-5 h-5 text-zinc-300' xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'>
						<line x1='4' x2='20' y1='6' y2='6'></line>
						<line x1='4' x2='20' y1='12' y2='12'></line>
						<line x1='4' x2='20' y1='18' y2='18'></line>
					</svg>
					<svg class='close-icon w-5 h-5 text-zinc-300 hidden' xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'>
						<line x1='18' x2='6' y1='6' y2='18'></line>
						<line x1='6' x2='18' y1='6' y2='18'></line>
					</svg>
				</button>

				<!-- Social Icons: Larger touch targets for accessibility -->
				<a class='p-2.5 rounded-lg hover:bg-[var(--color-bg-secondary)]/30 transition-colors duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] focus-visible:ring-offset-2' href='https://github.com/leandrodeobarbosa' target='_blank' aria-label='GitHub'>
					<SocialIcons icon="github" class="w-4 h-4 text-white hover:text-teal-400 transition-colors" />
				</a>
				<a class='p-2.5 rounded-lg hover:bg-[var(--color-bg-secondary)]/30 transition-colors duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] focus-visible:ring-offset-2' href='https://linkedin.com/in/leandrodeobarbosa' target='_blank' aria-label='LinkedIn'>
					<SocialIcons icon="linkedin" class="w-4 h-4 text-white hover:text-teal-400 transition-colors" />
				</a>
				<a class='p-2.5 rounded-lg hover:bg-[var(--color-bg-secondary)]/30 transition-colors duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] focus-visible:ring-offset-2' href='https://x.com/le_deobarbosa' target='_blank' aria-label='X/Twitter'>
					<SocialIcons icon="x" class="w-4 h-4 text-white hover:text-teal-400 transition-colors" />
				</a>

			</div>
		</nav>
	</div>

	<!-- Mobile Navigation Dropdown -->
	<div
		class='lg:hidden absolute top-full left-0 right-0 bg-[var(--color-bg-primary)]/90 backdrop-blur-xl border-b border-[var(--color-border-subtle)] shadow-2xl overflow-hidden transition-all duration-300 ease-in-out'
		id='mobileMenu'
		role='menu'
		aria-hidden='true'
	>
		<div class='container py-4'>
			<ul class='flex flex-col gap-1 font-mono text-sm'>
				{
					menu.map((item, index) => (
						<li>
							<HeaderLink
								class:list={[
									"flex items-center gap-2 px-4 py-3 rounded-lg text-zinc-200 hover:text-[var(--color-accent)] hover:bg-[var(--color-bg-secondary)]/30 transition-all duration-200",
									{ 'sobre-link': item.link === '/sobre/' }
								]}
								href={item.link}
								role='menuitem'
							>
								<span class="text-[var(--color-accent)] opacity-60">~{index}</span>
								{item.label}
							</HeaderLink>
						</li>
					))
				}
			</ul>
		</div>
	</div>
</header>

<style is:global>
	/* Terminal file indicator - special styling for files */
	.terminal-file {
		/* Icon removed per user request */
	}

	.group:hover .terminal-file::before {
		/* Animation removed */
	}

	@keyframes file-pulse {
		0%, 100% { transform: scale(1); }
		50% { transform: scale(1.2); }
	}

	/* Terminal ellipsis effect - modern glow */
	.terminal-ellipsis {
		position: relative;
		display: inline-block;
		font-weight: 600;
	}

	.terminal-ellipsis::after {
		content: '';
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 150%;
		height: 100%;
		background: linear-gradient(90deg, transparent, rgba(34, 197, 94, 0.2), transparent);
		opacity: 0;
		transition: opacity 0.3s ease;
		pointer-events: none;
		border-radius: 2px;
	}

	.group:hover .terminal-ellipsis::after {
		opacity: 1;
	}





	/* Mobile menu animation */
	#mobileMenu {
		max-height: 0;
		opacity: 0;
		visibility: hidden;
	}

	#mobileMenu.open {
		max-height: 300px;
		opacity: 1;
		visibility: visible;
	}

	/* Hamburger icon animation */
	#mobileMenuBtn .close-icon {
		display: none;
	}

	#mobileMenuBtn.open .menu-icon {
		display: none;
	}

	#mobileMenuBtn.open .close-icon {
		display: block;
	}

	/* Terminal cursor effect */
	@keyframes blink-cursor {
		0%, 100% { opacity: 1; }
		50% { opacity: 0; }
	}

	#terminal-text {
		white-space: nowrap;
	}

	#terminal-cursor {
		display: inline-block;
		width: 0.5ch;
		height: 1em;
		border: 1.5px solid var(--color-accent);
		padding: 2px;
		animation: blink-cursor 1.2s ease-in-out infinite;
		vertical-align: middle;
		margin-left: 2px;
		margin-top: 0.15em;
		opacity: 0.8;
		box-sizing: border-box;
	}

	/* Reduced motion */
	@media (prefers-reduced-motion: reduce) {
		#mobileMenu {
			transition: none;
			max-height: none;
			opacity: 1;
			visibility: visible;
		}
		#terminal-text, #terminal-cursor {
			border-right-color: transparent;
			animation: none;
		}
	}

	/* Mobile menu enhancements */
	#mobileMenu {
		background: linear-gradient(180deg, rgba(10, 10, 11, 0.95) 0%, rgba(10, 10, 11, 0.98) 100%);
		backdrop-filter: blur(20px) saturate(180%);
		-webkit-backdrop-filter: blur(20px) saturate(180%);
	}

	/* Social icons hover enhancement */
	header a:hover {
		background: rgba(24, 24, 27, 0.3);
	}

	/* Header border enhancement */
	#site-header {
		border-bottom-color: rgba(63, 63, 70, 0.3);
	}

	/* Mobile menu item hover */
	#mobileMenu a:hover {
		background: rgba(24, 24, 27, 0.5);
	}

	/* Hamburger button enhancement */
	#mobileMenuBtn:hover {
		background: rgba(24, 24, 27, 0.5);
	}

	/* Navigation links enhancement */
	header nav a:hover {
		background: rgba(24, 24, 27, 0.3);
	}

	/* Header background enhancement */
	#site-header {
		background: rgba(10, 10, 11, 0.95);
		backdrop-filter: blur(12px) saturate(180%);
		-webkit-backdrop-filter: blur(12px) saturate(180%);
	}

	/* Header link hover enhancement */
	#site-header a:hover {
		color: var(--color-accent);
	}

	/* Remove hover effects from terminal prompt link */
	#site-header h2 a:hover {
		background: transparent;
		color: inherit;
	}

	/* Header button hover enhancement */
	#site-header button:hover {
		background: rgba(24, 24, 27, 0.5);
	}

	/* Header icon hover enhancement */
	#site-header a:hover img {
		opacity: 1;
	}

	/* Header icon hover enhancement */
	#site-header a:hover svg {
		color: var(--color-accent);
	}
</style>

<script>
	// Ensure dark mode is always active
	document.documentElement.classList.add('dark');

	// Store references for cleanup with proper types
	let menuToggleHandler: (() => void) | null = null;
	let escapeKeyHandler: ((e: KeyboardEvent) => void) | null = null;
	let outsideClickHandler: ((e: MouseEvent) => void) | null = null;
	let scrollHandler: (() => void) | null = null;
	let isMenuInitialized = false;

	function cleanupMobileMenu() {
		const mobileMenuBtn = document.getElementById('mobileMenuBtn');
		const mobileMenu = document.getElementById('mobileMenu');

		if (!mobileMenuBtn || !mobileMenu) return;

		// Remove event listeners safely
		if (menuToggleHandler) mobileMenuBtn.removeEventListener('click', menuToggleHandler);
		if (escapeKeyHandler) document.removeEventListener('keydown', escapeKeyHandler);
		if (outsideClickHandler) document.removeEventListener('click', outsideClickHandler);
		if (scrollHandler) window.removeEventListener('scroll', scrollHandler);

		// Reset state
		mobileMenuBtn.classList.remove('open');
		mobileMenu.classList.remove('open');
		mobileMenuBtn.setAttribute('aria-expanded', 'false');
		mobileMenu.setAttribute('aria-hidden', 'true');

		menuToggleHandler = null;
		escapeKeyHandler = null;
		outsideClickHandler = null;
		scrollHandler = null;
		isMenuInitialized = false;
	}

	// Mobile menu toggle
	function initMobileMenu() {
		// Prevent multiple initializations
		if (isMenuInitialized) {
			cleanupMobileMenu();
		}

		const mobileMenuBtn = document.getElementById('mobileMenuBtn');
		const mobileMenu = document.getElementById('mobileMenu');

		if (!mobileMenuBtn || !mobileMenu) {
			return;
		}

		function toggleMobileMenu() {
      if (!mobileMenuBtn || !mobileMenu) return;
			const isOpen = mobileMenuBtn.classList.toggle('open');
			mobileMenu.classList.toggle('open', isOpen);
			mobileMenuBtn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
			mobileMenu.setAttribute('aria-hidden', isOpen ? 'false' : 'true');
		}

		menuToggleHandler = toggleMobileMenu;
		mobileMenuBtn.addEventListener('click', menuToggleHandler);

		// Close mobile menu on escape key
		escapeKeyHandler = (e: KeyboardEvent) => {
			if (e.key === 'Escape' && mobileMenu?.classList.contains('open')) {
				mobileMenuBtn.classList.remove('open');
				mobileMenu.classList.remove('open');
				mobileMenuBtn.setAttribute('aria-expanded', 'false');
				mobileMenu.setAttribute('aria-hidden', 'true');
				mobileMenuBtn.focus();
			}
		};
		document.addEventListener('keydown', escapeKeyHandler);

		// Close mobile menu when clicking outside
		outsideClickHandler = (e: MouseEvent) => {
			if (mobileMenu.classList.contains('open') &&
				!mobileMenu.contains(e.target as Node) &&
				!mobileMenuBtn.contains(e.target as Node)) {
				mobileMenuBtn.classList.remove('open');
				mobileMenu.classList.remove('open');
				mobileMenuBtn.setAttribute('aria-expanded', 'false');
				mobileMenu.setAttribute('aria-hidden', 'true');
			}
		};
		document.addEventListener('click', outsideClickHandler);

		// Handle scroll: add border on scroll for better visual hierarchy
		const header = document.getElementById('site-header');

		scrollHandler = () => {
			const currentScroll = window.scrollY;

			if (currentScroll > 10) {
				header?.classList.add('border-b', 'border-[var(--color-border-subtle)]');
			} else {
				header?.classList.remove('border-b', 'border-[var(--color-border-subtle)]');
			}

		};
		window.addEventListener('scroll', scrollHandler, { passive: true });

		isMenuInitialized = true;
	}

	// Initialize
	initMobileMenu();

	// Re-initialize after navigation (View Transitions)
	document.addEventListener('astro:after-swap', initMobileMenu);
</script>
