---
import { GISCUS_CONFIG } from '../config/giscus';

export interface Props {
  term: string;
}

const { term } = Astro.props;

// Get current theme at build time - this will be the default theme
// The client-side JS will handle dynamic theme switching
const getInitialTheme = () => {
  // Default to light theme at build time
  // The client-side script will update this based on actual user preference
  return 'light';
};

const initialTheme = getInitialTheme();
---

{
  GISCUS_CONFIG.repo && (
    <section class="giscus-wrapper">
      <div class="giscus-header">
        <h2 class="giscus-title">
          <svg xmlns="http://www.w3.org/2000/svg" class="giscus-icon" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M18 10c0 3.866-3.582 7-8 7a8.841 8.841 0 01-4.083-.98L2 17l1.338-3.123C2.493 12.767 2 11.434 2 10c0-3.866 3.582-7 8-7s8 3.134 8 7zM7 9H5v2h2V9zm8 0h-2v2h2V9zM9 9h2v2H9V9z" clip-rule="evenodd" />
          </svg>
          Discussão
        </h2>
        <span class="giscus-counter" id="giscus-comment-count">
          <span class="giscus-loading-dots">
            <span class="giscus-dot"></span>
            <span class="giscus-dot"></span>
            <span class="giscus-dot"></span>
          </span>
        </span>
      </div>
      
      <p class="comments-intro">
        Discussão aberta via GitHub. Seja respeitoso e construtivo.
      </p>
      
      <div class="giscus-container">
        <script
          id="giscus-script"
          is:inline
          src='https://giscus.app/client.js'
          data-repo={GISCUS_CONFIG.repo}
          data-repo-id={GISCUS_CONFIG.repoId}
          data-category={GISCUS_CONFIG.category}
          data-category-id={GISCUS_CONFIG.categoryId}
          data-mapping='specific'
          data-term={term}
          data-strict={GISCUS_CONFIG.strict}
          data-reactions-enabled={GISCUS_CONFIG.reactionsEnabled}
          data-emit-metadata={GISCUS_CONFIG.emitMetadata}
          data-input-position={GISCUS_CONFIG.inputPosition}
          data-theme={initialTheme}
          data-lang={GISCUS_CONFIG.lang}
          data-loading='lazy'
          crossorigin='anonymous'
          async
        ></script>
      </div>
      <script is:inline>
        // Function to get current Giscus theme based on page theme
        function getGiscusTheme() {
          const isDark = document.documentElement.classList.contains('dark') || 
            (localStorage.getItem('theme') === 'dark' || 
             (!localStorage.getItem('theme') && window.matchMedia('(prefers-color-scheme: dark)').matches));
          return isDark ? 'noborder_dark' : 'light';
        }

        // Immediately apply theme before Giscus loads (inline, runs immediately)
        (function() {
          // Set the data-theme attribute on the script element immediately
          const script = document.getElementById('giscus-script');
          if (script) {
            script.setAttribute('data-theme', getGiscusTheme());
          }
          // Listen for Giscus ready event and set theme
          window.addEventListener('message', function giscusReady(event) {
            if (event.data.giscus?.config) {
              const giscusFrame = document.querySelector('.giscus-frame');
              if (giscusFrame && giscusFrame.contentWindow) {
                giscusFrame.contentWindow.postMessage(
                  { giscus: { setConfig: { theme: getGiscusTheme() } } },
                  'https://giscus.app'
                );
              }
              window.removeEventListener('message', giscusReady);
            }
          });
        })();

        // Update Giscus theme
        function updateGiscusTheme() {
          const giscusFrame = document.querySelector('.giscus-frame');
          if (giscusFrame && giscusFrame.contentWindow) {
            const theme = getGiscusTheme();
            giscusFrame.contentWindow.postMessage(
              { giscus: { setConfig: { theme: theme } } },
              'https://giscus.app'
            );
          }
        }

        // Apply theme on page load
        function applyGiscusThemeOnLoad() {
          // Wait for Giscus to load
          const checkGiscus = setInterval(() => {
            const giscusFrame = document.querySelector('.giscus-frame');
            if (giscusFrame) {
              updateGiscusTheme();
              clearInterval(checkGiscus);
            }
          }, 100);
          
          // Clear after 5 seconds if Giscus never loads
          setTimeout(() => clearInterval(checkGiscus), 5000);
        }

        // Listen for Giscus updates to refresh comments after posting
        function handleGiscusMessage(event) {
          if (typeof event.data !== 'object' || event.data === null) return;
          if (event.data.giscus) {
            const giscusData = event.data.giscus;
            
            // Update comment counter when Giscus loads or updates
            if (giscusData.topic === 'config') {
              const count = giscusData.commentCount;
              updateCommentCounter(count);
            }
            
            // Refresh when comments are added, updated, or deleted
            if (
              giscusData.topic === 'comment' ||
              giscusData.topic === 'createComment' ||
              giscusData.topic === 'deleteComment' ||
              giscusData.topic === 'updateComment' ||
              giscusData.topic === 'reply'
            ) {
              // Small delay to allow Giscus to process the update
              setTimeout(() => {
                if (window.giscus && typeof window.giscus.refresh === 'function') {
                  window.giscus.refresh();
                }
                // Also update the counter after any comment action
                if (window.giscus && typeof window.giscus.fetch === 'function') {
                  window.giscus.fetch();
                }
              }, 100);
            }
          }
        }

        function updateCommentCounter(count) {
          const counterEl = document.getElementById('giscus-comment-count');
          if (counterEl) {
            if (count !== undefined && count !== null) {
              if (count === 0) {
                counterEl.textContent = '0 comentários';
              } else if (count === 1) {
                counterEl.textContent = '1 comentário';
              } else {
                counterEl.textContent = count + ' comentários';
              }
            } else {
              // If no count available, show a default message
              counterEl.textContent = 'Comentar';
            }
            counterEl.classList.add('giscus-counter-loaded');
          }
        }

        // Set fallback timeout - if Giscus doesn't respond in 3 seconds, show default
        setTimeout(() => {
          const counterEl = document.getElementById('giscus-comment-count');
          if (counterEl && !counterEl.classList.contains('giscus-counter-loaded')) {
            counterEl.textContent = 'Comentar';
            counterEl.classList.add('giscus-counter-loaded');
          }
        }, 3000);

        // Wait for Giscus to load, then set up the listener
        window.addEventListener('message', handleGiscusMessage);
        
        // Apply theme on load
        applyGiscusThemeOnLoad();
        
        // Also try to get the count directly from Giscus iframe after load
        const checkGiscusCount = () => {
          const giscusFrame = document.querySelector('.giscus-frame');
          if (giscusFrame && giscusFrame.contentWindow) {
            giscusFrame.contentWindow.postMessage(
              { giscus: { setConfig: { emitMetadata: '1' } } },
              'https://giscus.app'
            );
          }
        };
        
        // Check for existing Giscus iframe periodically
        const interval = setInterval(() => {
          if (document.querySelector('.giscus-frame')) {
            checkGiscusCount();
            clearInterval(interval);
          }
        }, 500);
        
        // Clear interval after 5 seconds to avoid infinite checking
        setTimeout(() => clearInterval(interval), 5000);

        // Listen for theme changes
        const observer = new MutationObserver((mutations) => {
          mutations.forEach((mutation) => {
            if (mutation.attributeName === 'class' || mutation.attributeName === 'style') {
              updateGiscusTheme();
            }
          });
        });
        
        // Observe html element for class changes (theme toggle)
        observer.observe(document.documentElement, { attributes: true });
        
        // Also listen for localStorage changes (theme preference)
        window.addEventListener('storage', (e) => {
          if (e.key === 'theme') {
            updateGiscusTheme();
          }
        });
      </script>
    </section>
  )
}

<style>
  .giscus-wrapper {
    margin-top: 3rem;
    padding: 1.5rem;
    border-radius: 0.75rem;
    background-color: var(--color-bg-secondary, #F4F4F5);
    border: 1px solid var(--color-border-subtle, #E4E4E7);
    box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
  }

  :global(.dark) .giscus-wrapper {
    background-color: var(--color-bg-secondary, #18181B);
    border-color: var(--color-border-subtle, #27272A);
  }

  .giscus-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border, #D4D4D8);
  }

  :global(.dark) .giscus-header {
    border-bottom-color: var(--color-border, #3F3F46);
  }

  .giscus-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text-primary, #18181B);
    margin: 0;
    letter-spacing: -0.025em;
  }

  :global(.dark) .giscus-title {
    color: var(--color-text-primary, #FAFAFA);
  }

  .giscus-icon {
    width: 1.25rem;
    height: 1.25rem;
    color: var(--color-accent, #0D9488);
  }

  :global(.dark) .giscus-icon {
    color: var(--color-accent, #14B8A6);
  }

  .giscus-counter {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-secondary, #52525B);
    background-color: var(--color-bg-tertiary, #E4E4E7);
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
  }

  :global(.dark) .giscus-counter {
    color: var(--color-text-secondary, #A1A1AA);
    background-color: var(--color-bg-tertiary, #27272A);
  }

  .giscus-loading-dots {
    display: inline-flex;
    gap: 0.25rem;
  }

  .giscus-dot {
    width: 0.375rem;
    height: 0.375rem;
    background-color: var(--color-text-tertiary, #A1A1AA);
    border-radius: 50%;
    animation: giscus-bounce 1.4s infinite ease-in-out both;
  }

  .giscus-dot:nth-child(1) {
    animation-delay: -0.32s;
  }

  .giscus-dot:nth-child(2) {
    animation-delay: -0.16s;
  }

  @keyframes giscus-bounce {
    0%, 80%, 100% {
      transform: scale(0);
    }
    40% {
      transform: scale(1);
    }
  }

  .giscus-counter-loaded .giscus-loading-dots {
    display: none;
  }

  .comments-intro {
    font-size: 0.875rem;
    color: var(--color-text-secondary, #52525B);
    margin: 0 0 1.25rem 0;
    padding: 0.75rem 1rem;
    background-color: var(--color-bg-primary, #FFFFFF);
    border-radius: 0.5rem;
    border-left: 3px solid var(--color-accent, #0D9488);
  }

  :global(.dark) .comments-intro {
    color: var(--color-text-secondary, #A1A1AA);
    background-color: var(--color-bg-primary, #0A0A0B);
    border-left-color: var(--color-accent, #14B8A6);
  }

  .giscus-container {
    min-height: 200px;
  }

  /* Ensure Giscus iframe blends seamlessly */
  .giscus-container :global(.giscus) {
    width: 100%;
  }

  .giscus-container :global(.giscus-frame) {
    border: none;
    width: 100%;
  }
</style>
