---
import ProjectCard from './ProjectCard.astro';
import type { Project } from '../domains/portfolio/projects'

interface Props {
  projects: Project[];
  featured?: boolean;
  horizontal?: boolean;
  variantOverrides?: Record<string, 'featured' | 'secondary' | 'compact' | 'horizontal'>;
}

const { projects, featured = false, horizontal = false, variantOverrides = {} } = Astro.props;

// Simplified variant logic - prioritize consistent 2-column layout
// Featured gets a slightly larger visual emphasis within the 2-column constraint
type CardVariant = 'featured' | 'secondary' | 'compact' | 'horizontal';

const getCardVariant = (index: number, isFeatured: boolean, isHorizontal: boolean, projectName: string): CardVariant => {
  // Check if there's a variant override for this project
  if (variantOverrides[projectName]) {
    return variantOverrides[projectName];
  }
  if (isHorizontal) return 'horizontal';
  if (!isFeatured) return 'secondary';
  // In featured mode, first project gets emphasized treatment
  return index === 0 ? 'featured' : 'secondary';
};

// Create pairs to ensure balanced 2-column layout
const projectPairs: [Project, Project | null][] = [];
for (let i = 0; i < projects.length; i += 2) {
  projectPairs.push([
    projects[i],
    projects[i + 1] || null
  ]);
}
---

<div class="projects-grid" data-featured={featured} data-horizontal={horizontal}>
  {projectPairs.map(([project1, project2], pairIndex: number) => (
    <div class="projects-grid__row">
      <div class="projects-grid__item">
        <ProjectCard
          project={project1}
          variant={getCardVariant(pairIndex * 2, featured, horizontal, project1.name)}
        />
      </div>
      {project2 && (
        <div class="projects-grid__item">
          <ProjectCard
            project={project2}
            variant={getCardVariant(pairIndex * 2 + 1, featured, horizontal, project2.name)}
          />
        </div>
      )}
    </div>
  ))}
</div>

<style>
  .projects-grid {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* Each row maintains 2 columns */
  .projects-grid__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  /* Tablet and above: 2 columns per row */
  @media (min-width: 640px) {
    .projects-grid__row {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Ensure cards in the same row have equal height */
  .projects-grid__row > .projects-grid__item {
    display: flex;
  }

  .projects-grid__row > .projects-grid__item:only-child {
    /* Odd number of projects: full-width on mobile, half on tablet+ */
  }

    /* Featured card gets subtle visual emphasis */
  @media (min-width: 640px) {
    .projects-grid[data-featured="true"] .projects-grid__row:first-child .projects-grid__item:first-child::before {
      display: none;
    }
  }

  /* Desktop: maintain 2 columns with increased spacing */
  @media (min-width: 1024px) {
    .projects-grid {
      gap: 2.5rem;
    }

    .projects-grid__row {
      gap: 2.5rem;
    }
  }

  /* Large Desktop: consistent 2-column layout */
  @media (min-width: 1280px) {
    .projects-grid__row {
      gap: 3rem;
    }
  }

  /* Reduced motion support */
  @media (prefers-reduced-motion: reduce) {
    .projects-grid,
    .projects-grid__row {
      transition: none;
    }
  }

  /* Horizontal layout - full-width cards */
  .projects-grid[data-horizontal="true"] .projects-grid__row {
    grid-template-columns: 1fr;
  }

  .projects-grid[data-horizontal="true"] .projects-grid__item {
    width: 100%;
  }
</style>
