---
import HeaderLink from './HeaderLink.astro';
import { Image } from 'astro:assets';
import GithubWhite from '@src/assets/img/github-mark-white.svg';
import GithubBlack from '@src/assets/img/github-mark.svg';
import LinkedinWhite from '@src/assets/img/linkedin-white.svg';
import LinkedinBlack from '@src/assets/img/linkedin.svg';
import XWhite from '@src/assets/img/x-white.svg';
import XBlack from '@src/assets/img/x.svg';

const menu = [
	{
		link: '/',
		label: 'Home'
	},
	{
		link: '/projects/',
		label: 'Projects'
	},
	{
		link: '/posts/',
		label: 'Posts'
	},
	{
		link: '/about/',
		label: 'About'
	},
];

	// Get current path for terminal PWD display
	const currentPath = Astro.url.pathname;
	const normalizedPath = currentPath.replace(/\/$/, '').slice(1) || '';
	const pathSegments = normalizedPath.split('/').filter(Boolean);
	const displayPath = pathSegments.length > 0 ? '~/' + pathSegments.slice(0, 2).join('/') : '~';
---

<header
	id='site-header'
	class:list={[
		'fixed top-0 left-0 right-0 flex items-center w-full transition-all duration-300 z-[999] bg-[var(--color-bg-primary)]/95 dark:bg-[var(--color-bg-primary)]/95 backdrop-blur-md border-b border-transparent dark:border-transparent'
	]}
>
	<div class='container'>
		<nav class='flex gap-4 items-center justify-between py-3'>
			<!-- Logo Section (Left) -->
			<h2 class='m-0'>
				<a href='/' class='group flex gap-2 items-center text-sm font-bold no-underline font-mono opacity-90 hover:opacity-100 transition-all duration-200' aria-label='Home - leandro@portfolio'>
					<span class="text-[var(--color-accent)]">leandro@portfolio</span>
					<span class="text-zinc-500 dark:text-zinc-400">:</span>
					<span class="text-zinc-800 dark:text-zinc-200 truncate max-w-[120px] sm:max-w-[200px] group-hover:text-[var(--color-accent)] transition-colors duration-200">{displayPath}</span>
				</a>
			</h2>

			<!-- Navigation Links (Terminal Style - File Directory Tabs) -->
			<div class='hidden lg:flex items-center gap-1 font-mono text-sm'>
				{
					menu.map((item) => (
						<HeaderLink 
							class="px-3 py-2 text-zinc-500 dark:text-zinc-400 hover:text-[var(--color-accent)] hover:bg-[var(--color-bg-secondary)] dark:hover:bg-[var(--color-bg-secondary)] rounded transition-all duration-200" 
							href={item.link}
						>
							<span class="text-[var(--color-accent)] opacity-50">/</span>{item.label}
						</HeaderLink>
					))
				}
			</div>

			<!-- Social Icons & Theme Toggle (Right) -->
			<div class='flex items-center gap-1'>
				<!-- Mobile: Hamburger Menu -->
				<button 
					class='lg:hidden p-2.5 rounded-lg hover:bg-[var(--color-bg-secondary)] dark:hover:bg-[var(--color-bg-secondary)] transition-colors duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] focus-visible:ring-offset-2'
					id='mobileMenuBtn'
					aria-label='Toggle navigation menu'
					aria-expanded='false'
					aria-controls='mobileMenu'
				>
					<svg class='menu-icon w-5 h-5 text-zinc-600 dark:text-zinc-300' xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'>
						<line x1='4' x2='20' y1='6' y2='6'></line>
						<line x1='4' x2='20' y1='12' y2='12'></line>
						<line x1='4' x2='20' y1='18' y2='18'></line>
					</svg>
					<svg class='close-icon w-5 h-5 text-zinc-600 dark:text-zinc-300 hidden' xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'>
						<line x1='18' x2='6' y1='6' y2='18'></line>
						<line x1='6' x2='18' y1='6' y2='18'></line>
					</svg>
				</button>

				<!-- Social Icons: Larger touch targets for accessibility -->
				<a class='p-2.5 rounded-lg hover:bg-[var(--color-bg-secondary)] dark:hover:bg-[var(--color-bg-secondary)] transition-colors duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] focus-visible:ring-offset-2' href='https://github.com/leandrodeobarbosa' target='_blank' aria-label='GitHub'>
					<Image class='w-5 h-5 dark:hidden opacity-70 hover:opacity-100 transition-opacity' src={GithubBlack} width={20} height={20} alt='Github logo' />
					<Image class='w-5 h-5 hidden dark:block opacity-70 hover:opacity-100 transition-opacity' src={GithubWhite} width={20} height={20} alt='Github logo' />
				</a>
				<a class='p-2.5 rounded-lg hover:bg-[var(--color-bg-secondary)] dark:hover:bg-[var(--color-bg-secondary)] transition-colors duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] focus-visible:ring-offset-2' href='https://linkedin.com/in/leandrodeobarbosa' target='_blank' aria-label='LinkedIn'>
					<Image class='w-5 h-5 dark:hidden opacity-70 hover:opacity-100 transition-opacity' src={LinkedinBlack} width={20} height={20} alt='LinkedIn logo' />
					<Image class='w-5 h-5 hidden dark:block opacity-70 hover:opacity-100 transition-opacity' src={LinkedinWhite} width={20} height={20} alt='LinkedIn logo' />
				</a>
				<a class='p-2.5 rounded-lg hover:bg-[var(--color-bg-secondary)] dark:hover:bg-[var(--color-bg-secondary)] transition-colors duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] focus-visible:ring-offset-2' href='https://x.com/leandrodeobarbosa' target='_blank' aria-label='X/Twitter'>
					<Image class='w-5 h-5 dark:hidden opacity-70 hover:opacity-100 transition-opacity' src={XBlack} width={20} height={20} alt='X logo' />
					<Image class='w-5 h-5 hidden dark:block opacity-70 hover:opacity-100 transition-opacity' src={XWhite} width={20} height={20} alt='X logo' />
				</a>
				<button class='p-2.5 rounded-lg hover:bg-[var(--color-bg-secondary)] dark:hover:bg-[var(--color-bg-secondary)] transition-colors duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] focus-visible:ring-offset-2' id='themeToggle' aria-label='Toggle theme mode'>
					<svg
						class='sun w-5 h-5'
						xmlns='http://www.w3.org/2000/svg'
						viewBox='0 0 24 24'
						fill='none'
						stroke='currentColor'
						stroke-width='2'
						stroke-linecap='round'
						stroke-linejoin='round'
						><circle cx='12' cy='12' r='4'></circle><path d='M12 2v2'></path><path d='M12 20v2'></path><path d='m4.93 4.93 1.41 1.41'
						></path><path d='m17.66 17.66 1.41 1.41'></path><path d='M2 12h2'></path><path d='M20 12h2'></path><path
							d='m6.34 17.66-1.41 1.41'></path><path d='m19.07 4.93-1.41 1.41'></path></svg
					>
					<svg
						class='moon w-5 h-5'
						xmlns='http://www.w3.org/2000/svg'
						viewBox='0 0 24 24'
						fill='none'
						stroke='currentColor'
						stroke-width='2'
						stroke-linecap='round'
						stroke-linejoin='round'
					>
						<path d='M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z'></path></svg
					>
				</button>
			</div>
		</nav>
	</div>

	<!-- Mobile Navigation Dropdown -->
	<div 
		class='lg:hidden absolute top-full left-0 right-0 bg-[var(--color-bg-primary)] dark:bg-[var(--color-bg-primary)] border-b border-[var(--color-border-subtle)] shadow-lg dark:shadow-none overflow-hidden transition-all duration-300 ease-in-out'
		id='mobileMenu'
		role='menu'
		aria-hidden='true'
	>
		<div class='container py-4'>
			<ul class='flex flex-col gap-1 font-mono text-sm'>
				{
					menu.map((item, index) => (
						<li>
							<HeaderLink 
								class="flex items-center gap-2 px-4 py-3 rounded-lg text-zinc-600 dark:text-zinc-300 hover:text-[var(--color-accent)] hover:bg-[var(--color-bg-secondary)] dark:hover:bg-[var(--color-bg-secondary)] transition-all duration-200" 
								href={item.link}
								role='menuitem'
							>
								<span class="text-[var(--color-accent)] opacity-60">~{index}</span>
								{item.label}
							</HeaderLink>
						</li>
					))
				}
			</ul>
		</div>
	</div>
</header>

<style is:global>
	#themeToggle .moon {
		display: none;
	}
	.dark #themeToggle .sun {
		display: none;
	}
	.dark #themeToggle .moon {
		display: block;
	}

	/* Mobile menu animation */
	#mobileMenu {
		max-height: 0;
		opacity: 0;
		visibility: hidden;
	}

	#mobileMenu.open {
		max-height: 300px;
		opacity: 1;
		visibility: visible;
	}

	/* Hamburger icon animation */
	#mobileMenuBtn .close-icon {
		display: none;
	}

	#mobileMenuBtn.open .menu-icon {
		display: none;
	}

	#mobileMenuBtn.open .close-icon {
		display: block;
	}

	/* Reduced motion */
	@media (prefers-reduced-motion: reduce) {
		#mobileMenu {
			transition: none;
			max-height: none;
			opacity: 1;
			visibility: visible;
		}
	}
</style>

<script is:inline>
	// Handle theme initialization and persistence
	const theme = (() => {
		if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
			return localStorage.getItem('theme');
		}
		if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
			return 'dark';
		}
		return 'light';
	})();

	if (theme === 'light') {
		document.documentElement.classList.remove('dark');
	} else {
		document.documentElement.classList.add('dark');
	}

	window.localStorage.setItem('theme', theme || '');

	// Listen for system theme changes
	window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
		if (!localStorage.getItem('theme')) {
			if (e.matches) {
				document.documentElement.classList.add('dark');
			} else {
				document.documentElement.classList.remove('dark');
			}
		}
	});

	function sendMessage(message) {
		const iframe = document.querySelector('iframe.giscus-frame');
		if (!iframe) return;
		iframe.contentWindow.postMessage({ giscus: message }, 'https://giscus.app');
	}

	const handleToggleClick = () => {
		const element = document.documentElement;
		element.classList.toggle('dark');

		const isDark = element.classList.contains('dark');
		if (isDark) {
			sendMessage({
				setConfig: {
					theme: 'dark_dimmed'
				}
			});
		} else {
			sendMessage({
				setConfig: {
					theme: 'light'
				}
			});
		}
		localStorage.setItem('theme', isDark ? 'dark' : 'light');
	};
	document.getElementById('themeToggle')?.addEventListener('click', handleToggleClick);

	// Mobile menu toggle
	const mobileMenuBtn = document.getElementById('mobileMenuBtn');
	const mobileMenu = document.getElementById('mobileMenu');

	function toggleMobileMenu() {
		const isOpen = mobileMenuBtn.classList.toggle('open');
		mobileMenu.classList.toggle('open', isOpen);
		mobileMenuBtn.setAttribute('aria-expanded', isOpen);
		mobileMenu.setAttribute('aria-hidden', !isOpen);
	}

	mobileMenuBtn?.addEventListener('click', toggleMobileMenu);

	// Close mobile menu on escape key
	document.addEventListener('keydown', (e) => {
		if (e.key === 'Escape' && mobileMenu?.classList.contains('open')) {
			mobileMenuBtn?.classList.remove('open');
			mobileMenu.classList.remove('open');
			mobileMenuBtn?.setAttribute('aria-expanded', 'false');
			mobileMenu?.setAttribute('aria-hidden', 'true');
			mobileMenuBtn?.focus();
		}
	});

	// Close mobile menu when clicking outside
	document.addEventListener('click', (e) => {
		if (mobileMenu?.classList.contains('open') && 
			!mobileMenu.contains(e.target) && 
			!mobileMenuBtn?.contains(e.target)) {
			mobileMenuBtn?.classList.remove('open');
			mobileMenu.classList.remove('open');
			mobileMenuBtn?.setAttribute('aria-expanded', 'false');
			mobileMenu?.setAttribute('aria-hidden', 'true');
		}
	});

	// Handle scroll: add border on scroll for better visual hierarchy
	let lastScroll = 0;
	const header = document.getElementById('site-header');

	window.addEventListener('scroll', () => {
		const currentScroll = window.pageYOffset;
		
		if (currentScroll > 10) {
			header?.classList.add('border-b', 'border-[var(--color-border-subtle)]');
		} else {
			header?.classList.remove('border-b', 'border-[var(--color-border-subtle)]');
		}
		
		lastScroll = currentScroll;
	}, { passive: true });
</script>
