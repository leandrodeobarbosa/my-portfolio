---
import { Image } from 'astro:assets';
import Ava from '@src/assets/img/ava.jpg';

type PicSize = 'sm' | 'md' | 'lg';
interface Props {
	picSize: PicSize;
}
const { picSize } = Astro.props;
---

<div class='flex gap-4 items-center leading-tight not-prose'>
	<a
		href='https://github.com/syakirurahman'
		target='_blank'
		rel='noopener noreferrer'
		class:list={[
			'rounded-lg overflow-hidden shrink-0 bg-gradient-to-br from-zinc-100 to-zinc-200 dark:from-zinc-800 dark:to-zinc-900 border border-zinc-200/50 dark:border-zinc-700/50 shadow-sm',
			{ 'w-12 h-12': picSize === 'sm' },
			{ 'w-[70px] h-[70px]': picSize === 'md' },
			{ 'w-[90px] h-[90px]': picSize === 'lg' }
		]}
	>
		<Image src={Ava} alt='Leandro de Oliveira Barbosa' class="w-full h-full object-cover"/>
	</a>
	<div>
		<div>
			<a
				href='https://github.com/syakirurahman'
				class='block font-bold text-inherit hover:text-[var(--link-color)]'
				target='_blank'
				rel='noopener noreferrer'
			>
				Leandro de Oliveira Barbosa
			</a>
		</div>
		<small class='avatar__subtitle'>DevOps Engineer</small>
	</div>
</div>
