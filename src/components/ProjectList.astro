---
import { Image } from 'astro:assets';
import type { Project } from '../pages/projects/projects'
import { kFormatter } from '../utils'
import GithubWhite from '@src/assets/img/github-mark-white.svg';
import GithubBlack from '@src/assets/img/github-mark.svg';

const { projects } = Astro.props

const techIcons: Record<string, string> = {
  fedora: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/fedora/fedora-original.svg',
  terminal: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/ubuntu/ubuntu-plain.svg',
  bash: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/bash/bash-original.svg',
  shell: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/bash/bash-original.svg',
  javascript: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/javascript/javascript-original.svg',
  js: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/javascript/javascript-original.svg',
  typescript: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/typescript/typescript-original.svg',
  ts: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/typescript/typescript-original.svg',
  docker: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/docker/docker-original.svg',
  kubernetes: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/kubernetes/kubernetes-plain.svg',
  k8s: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/kubernetes/kubernetes-plain.svg',
  terraform: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/terraform/terraform-original.svg',
  prometheus: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/prometheus/prometheus-original.svg',
  grafana: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/grafana/grafana-original.svg',
  githubactions: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/githubactions/githubactions-original.svg',
  actions: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/githubactions/githubactions-original.svg',
  aws: 'https://img.icons8.com/color/48/amazon-web-services.png',
  oci: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/oracle/oracle-original.svg',
  oracle: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/oracle/oracle-original.svg',
  astro: 'https://api.iconify.design/skill-icons:astro.svg',
  tailwind: 'https://img.icons8.com/color/48/tailwindcss.png',
  html: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/html5/html5-original.svg',
  css: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/css3/css3-original.svg',
};

---
<div class="grid grid-cols-12 gap-5">
  {
    projects.map((project: Project) => 
      <div class="col-span-12 sm:col-span-6 lg:col-span-4 bg-white dark:bg-zinc-800 border dark:border-zinc-700 rounded-xl p-5 hover:border-[var(--color-accent)] hover:shadow-lg transition-all duration-300 group flex flex-col h-full">
        <div class="flex justify-between items-start mb-3">
          <div class='flex gap-2 flex-wrap'>
            {
              (project.tags || [] )?.map((tag: string) => (
                <span
                  class='border border-zinc-300 dark:border-zinc-700 rounded-2xl
                    text-sm text-zinc-700 dark:text-zinc-300 no-underline px-2 py-0.5
                    transition-all duration-200
                  hover:bg-zinc-100 dark:hover:bg-zinc-800 hover:border-zinc-700 dark:hover:border-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100'
                  >
                  {tag}
                </span>
              ))
            }
          </div>

          {project.stargazers_count !== undefined && (
            <div class='shrink-0'>
              <a
                href={project.html_url}
                target="_blank"
                class='border border-zinc-300 dark:border-zinc-700 rounded-2xl
                    text-xs text-zinc-700 dark:text-zinc-300 no-underline px-2 py-0.5
                    transition-all duration-200
                  hover:bg-zinc-100 dark:hover:bg-zinc-800 hover:border-zinc-700 dark:hover:border-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100
                    flex items-center gap-1
              '>
                <Image src={GithubBlack} height={12} class='dark:hidden' alt='Github stars' />
                <Image src={GithubWhite} height={12} class='hidden dark:block' alt='Github stars' />
                {kFormatter(project.stargazers_count)} stars
              </a>
            </div>
          )}
        </div>
        <h3 class="font-semibold text-lg mb-2 group-hover:text-[var(--color-accent)] transition-colors">
          <a href={project.demoLink} target="_blank" rel={project.demoLinkRel}>{project.name}</a>
        </h3>
        <div class="text-zinc-600 dark:text-zinc-300 mb-4 line-clamp-2 text-sm leading-relaxed">
          {project.description}
        </div>
        
        {/* Technology Icons at bottom */}
        {(project.techIcons || [] )?.length > 0 && (
          <div class="flex flex-col gap-2 pt-3 mt-auto">
            <span class="text-xs font-medium text-zinc-400 uppercase tracking-wider">Technologies</span>
            <div class="flex flex-wrap gap-2.5 items-center">
              {
                (project.techIcons || [] )?.map((iconName: string) => {
                  const iconUrl = techIcons[iconName.toLowerCase()];
                  const isFedora = iconName.toLowerCase() === 'fedora';
                  const isJs = iconName.toLowerCase() === 'javascript' || iconName.toLowerCase() === 'js';
                  const isGithubActions = iconName.toLowerCase() === 'githubactions' || iconName.toLowerCase() === 'actions';
                  // Icons that should keep original colors in dark mode
                  const keepOriginal = ['typescript', 'ts', 'docker', 'astro', 'tailwind', 'html', 'css', 'kubernetes', 'k8s', 'terraform', 'prometheus', 'grafana', 'aws', 'oci', 'oracle'];
                  const shouldKeepColor = isFedora || isJs || isGithubActions || keepOriginal.includes(iconName.toLowerCase());
                  return iconUrl ? (
                    <img 
                      src={iconUrl} 
                      width={20} 
                      height={20} 
                      alt={iconName} 
                      class={`w-5 h-5 object-contain ${shouldKeepColor ? '' : 'dark:brightness-75 dark:invert'}`} 
                    />
                  ) : null;
                })
              }
            </div>
          </div>
        )}
        
        <div class="flex justify-end gap-3 pt-2">
          {
            project.postLink &&
            <a class="underline flex items-center gap-2" href={project.postLink}>
              Article
            </a>
          }
          {
            project.demoLink &&  // This line adds the conditional check for the Demo link
            <a class="underline flex items-center gap-2" href={project.demoLink} target="_blank" rel={project.demoLinkRel}>
              Demo 
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-external-link"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
            </a>
          }
        </div>
      </div>
    )
  }
</div>
