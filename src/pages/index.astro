---
import { SITE_TITLE, SITE_TAGLINE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';
import { projects } from './projects/projects';
import ProjectList from '../components/ProjectList.astro'
import PostItem from '../components/PostItem.astro';
import { Image } from 'astro:assets';

type BlogPost = CollectionEntry<'blog'>;

const top6Projects = projects.slice(0, 6);
const posts = (await getCollection('blog')).sort((a: BlogPost, b: BlogPost) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 5);
---

<BaseLayout title={SITE_TITLE + ' - ' + SITE_TAGLINE} description={SITE_DESCRIPTION}>
	<div class='container'>
		<main>
			<!-- Documentation Style Hero Section -->
			<div class='max-w-4xl mb-16'>
				<!-- Name, Seniority Micro-signal, and Keywords -->
				<div class='flex-1 min-w-0 pt-1'>
					<h1 class='text-3xl sm:text-4xl font-bold text-zinc-900 dark:text-zinc-50 font-mono mb-2'>
						Leandro de Oliveira Barbosa
					</h1>
					<!-- Seniority Micro-signal -->
					<p class='text-xs text-zinc-400 dark:text-zinc-500 font-mono mb-3 tracking-tight'>
						<span>OCI Certified</span>
						<span class='mx-1'>•</span>
						<span>SRE Mindset</span>
					</p>
			
			<!-- Introduction -->
			<p class='text-lg sm:text-xl leading-relaxed mb-8 text-zinc-700 dark:text-zinc-200/90 max-w-[65ch]'>
				<span class='font-semibold text-[var(--color-accent)]'>Engenheiro DevOps</span> com base em
				<span class='font-medium'> Desenvolvimento de Software</span> e foco em
				<span class='font-medium'> Plataforma,</span>
				<span class='font-medium'> Cloud</span> e 
				<span class='font-medium'> Automação</span>. Construo pipelines e ambientes confiáveis que transformam código em entrega sustentável.
			</p>
			</div>
			
			<hr class='border-t border-[var(--color-border-subtle)] mb-12' />
			
			<!-- Projects - Markdown Style Header -->
			<div class='mb-12'>
				<div class='flex justify-between gap-2 mb-6'>
					<h2 class='text-xl font-mono font-bold text-zinc-900 dark:text-zinc-100'>## Projects</h2>
					<a href='/projects/' class='text-sm text-zinc-500 dark:text-zinc-400 hover:text-[var(--color-accent)] no-underline font-mono'>[ All projects ]</a>
				</div>
				<ProjectList projects={top6Projects} featured={true}/>
			</div>
			
			<hr class='border-t border-[var(--color-border-subtle)] mb-12' />
			
			<!-- Tech Stack - Markdown Style Header -->
			<div class='mb-12'>
				<h2 class='text-xl font-mono font-bold text-zinc-900 dark:text-zinc-100 mb-4 mt-10'>## Tech Stack</h2>
				
				<!-- Skills Grid -->
				<div class='grid grid-cols-2 sm:grid-cols-3 gap-x-8 gap-y-3 mb-8'>
					<div class='flex items-center gap-2'>
						<span class='text-[var(--color-accent)]'>▸</span>
						<span class='text-sm text-zinc-600 dark:text-zinc-300'>Infrastrucure as Code</span>
					</div>
					<div class='flex items-center gap-2'>
						<span class='text-[var(--color-accent)]'>▸</span>
						<span class='text-sm text-zinc-600 dark:text-zinc-300'>Containerization & Orchestration</span>
					</div>
					<div class='flex items-center gap-2'>
						<span class='text-[var(--color-accent)]'>▸</span>
						<span class='text-sm text-zinc-600 dark:text-zinc-300'>CI/CD & Automation</span>
					</div>
					<div class='flex items-center gap-2'>
						<span class='text-[var(--color-accent)]'>▸</span>
						<span class='text-sm text-zinc-600 dark:text-zinc-300'>Linux Systems</span>
					</div>
					<div class='flex items-center gap-2'>
						<span class='text-[var(--color-accent)]'>▸</span>
						<span class='text-sm text-zinc-600 dark:text-zinc-300'>Identity & Integrations</span>
					</div>
				</div>
			</div>
			
			<hr class='border-t border-[var(--color-border-subtle)] mb-12' />
			
			<!-- Recent Posts - Markdown Style Header -->
			<div class='mb-12'>
				<div class='flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-6'>
					<h2 class='text-xl font-mono font-bold text-zinc-900 dark:text-zinc-100'>## Recent Posts</h2>
					<a href='/posts/' class='text-sm text-zinc-500 dark:text-zinc-400 hover:text-[var(--color-accent)] no-underline font-mono'>[ View all ]</a>
				</div>
				<div class='space-y-0'>
					{
						posts.map((post: BlogPost) => (
							<PostItem post={post} />
						))
					}      
				</div>
			</div>
		</main>
	</div>
</BaseLayout>
